PORT=4000
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=12h
# Pooler (порт 6543) — для работы приложения. Спецсимволы в пароле кодируйте: ! -> %21
DATABASE_URL=postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres
# Прямое подключение (порт 5432) — опционально только для миграций, если pooler обрывает соединение
# DATABASE_MIGRATION_URL=postgresql://USER:PASSWORD@db.HOSTREF.supabase.co:5432/postgres
PG_SSL=true
PG_SSL_REJECT_UNAUTHORIZED=false
CORS_ORIGIN=http://localhost:4000,http://localhost:5500
